# =============================================================================
# ATRELLIS — DIDI AGENT ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# --- Claude (Primary LLM) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Gemini (Secondary LLM / Image Analysis) ---
GEMINI_API_KEY=AIza...

# --- Firebase Admin SDK ---
# 1. Go to Firebase Console → https://console.firebase.google.com
# 2. Create project → name it "Atrellis_Database_Agent"
# 3. Enable Firestore Database (production mode)
# 4. Project Settings → Service Accounts → Generate New Private Key
# 5. Copy the three values below from the downloaded JSON file
FIREBASE_PROJECT_ID=atrellis-database-agent
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@atrellis-database-agent.iam.gserviceaccount.com
# Paste the private key in quotes — keep the \n as literal backslash-n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# --- Telegram Bot (Atrellis_Didi_bot) ---
# REGENERATE this token via @BotFather after initial demo setup
TELEGRAM_BOT_TOKEN=8714205006:AAHJIuR4vBkXQ0510RdLAoHQ0bX-RpVQHuw

# Andrew's Telegram numeric chat_id (NOT the username).
# How to get: Andrew sends /start to @Atrellis_Didi_bot → auto-saved.
# Manual fallback: https://api.telegram.org/bot<TOKEN>/getUpdates → "chat":{"id":...}
TELEGRAM_ANDREW_CHAT_ID=

