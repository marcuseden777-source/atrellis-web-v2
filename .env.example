# =============================================================================
# ATRELLIS — DIDI AGENT ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# --- Claude (Primary LLM) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Gemini (Secondary LLM / Image Analysis) ---
GEMINI_API_KEY=AIza...

# --- Firebase Admin SDK (Atrellis_Database_Agent project) ---
# From Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=atrellis-database-agent
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@atrellis-database-agent.iam.gserviceaccount.com
# Paste the private key in quotes, replacing literal \n with actual newlines
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# --- Telegram Bot (Atrellis_Didi_bot) ---
# Token from @BotFather — regenerate this after the initial demo setup
TELEGRAM_BOT_TOKEN=8714205006:AAHJIuR4vBkXQ0510RdLAoHQ0bX-RpVQHuw

# Andrew's Telegram numeric chat_id (NOT username).
# To get it: message @Atrellis_Didi_bot as Andrew, then call
# https://api.telegram.org/bot<TOKEN>/getUpdates — look for "chat":{"id":...}
TELEGRAM_ANDREW_CHAT_ID=

# Andrew's WhatsApp fallback (used in Make.com future integration)
ANDREW_WHATSAPP=+6592223333

# --- Make.com Webhook (Future / Placeholder) ---
# Paste your Make.com scenario webhook URL here when ready
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/PLACEHOLDER

# --- App ---
NEXT_PUBLIC_APP_URL=https://atrellis.business
